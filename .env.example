APP_NAME="AC Academia"
# Use "local" em desenvolvimento. Qualquer outro valor (ex.: "production") ativa
# validacoes de seguranca que recusam segredos/senhas fracos no boot.
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://ac_academia:ac_academia@db:5432/ac_academia
# Em producao, gere um valor aleatorio forte (>=32 caracteres):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-esta-chave-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=720
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTO_CREATE_ADMIN=true
FIRST_ADMIN_NAME=Administrador
FIRST_ADMIN_EMAIL=admin@acacademia.com.br
# Em producao, defina uma senha forte (admin123 e outras triviais sao recusadas).
FIRST_ADMIN_PASSWORD=admin123
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:3000
UPLOAD_DIR=uploads
# Limite por upload de imagem em ficha de treino (bytes). Padrao: 10MB.
TRAINING_MEDIA_MAX_BYTES=10485760
